# Files Wrangler should NOT upload as public assets.
# Same syntax as .gitignore. Keeps repo internals off the live site.

# Version control & local agent/workspace config
.git/
.claude/
.gitignore

# Cloudflare config (consumed by the runtime, not served as files)
wrangler.jsonc
_headers
_redirects
.assetsignore

# Project docs / source that should not be public
AGENTS.md
CLAUDE.md
CLAUDE.md.backup
README.md
VERSION
scripts/
docs/

# Backend / tooling, not part of the public site
google-apps-script/
server.py

# Worker source & D1 migrations (code/runtime, not served as files)
worker/
migrations/
.github/

# GitHub Pages artifacts (not used on Cloudflare)
CNAME
.nojekyll

# Local Wrangler state (dev D1 snapshots, cache, deploy tmp/source maps)
.wrangler/
*.map

# Dependencies & junk
node_modules/
*.bak
.DS_Store
Thumbs.db
